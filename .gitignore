# ==================================================
# LIAO AI Assistant - Professional .gitignore
# ==================================================

# ----------------------------------
# Python
# ----------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/

# ----------------------------------
# Virtual Environment
# ----------------------------------
venv/
env/
ENV/
.venv/

# ----------------------------------
# Environment / Secrets
# ----------------------------------
.env
.env.*
*.env
secrets.json
credentials.json
service_account.json
apikey.txt
keys.txt

# ----------------------------------
# Database
# ----------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# ----------------------------------
# Logs
# ----------------------------------
logs/
data/logs/
*.log
*.out
*.err

# ----------------------------------
# Cache / Temp
# ----------------------------------
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
coverage/
htmlcov/
temp/
tmp/
*.tmp

# ----------------------------------
# IDE / Editor
# ----------------------------------
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# ----------------------------------
# OS Files
# ----------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ----------------------------------
# Testing / Reports
# ----------------------------------
.coverage
coverage.xml
nosetests.xml
pytestdebug.log

# ----------------------------------
# Build / Packaging
# ----------------------------------
*.spec
*.manifest

# ----------------------------------
# Media / Generated Files
# ----------------------------------
screenshots/
exports/
recordings/
audio_cache/
generated/
*.wav
*.mp3
*.mp4

# ----------------------------------
# Sensitive Project Data
# ----------------------------------
data/cache/*
!data/cache/__init__.py

data/logs/*
!data/logs/__init__.py

# ----------------------------------
# Frontend Cache
# ----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------
# Optional Local Config
# ----------------------------------
local_settings.py
user_config.json
private_config.json

# ----------------------------------
# Keep Structure Files
# ----------------------------------
!.gitkeep