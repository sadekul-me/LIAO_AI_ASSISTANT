# ==================================================
# LIAO AI Assistant - PRODUCTION GRADE .GITIGNORE
# ==================================================

# =========================================
# PYTHON CORE
# =========================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

*.egg
*.egg-info/
dist/
build/
develop-eggs/
downloads/
eggs/
wheels/

# =========================================
# VIRTUAL ENV
# =========================================
venv/
env/
ENV/
.venv/

# =========================================
# ENV & SECRETS (CRITICAL 🔥)
# =========================================
.env
.env.*
*.env

secrets.json
credentials.json
apikey.txt
keys.txt
service_account.json

# API / AI keys (extra safety)
openai_key*
groq_key*
deepseek_key*
openrouter_key*

# =========================================
# DATABASE / STORAGE
# =========================================
*.db
*.sqlite
*.sqlite3
*.db-journal

data/
!data/__init__.py

# =========================================
# LOGS (VERY IMPORTANT FOR AI DEBUG)
# =========================================
logs/
*.log
*.out
*.err

backend/logs/
frontend/logs/

# =========================================
# CACHE / TEMP (AI LATENCY SAFE)
# =========================================
.cache/
tmp/
temp/
.pytest_cache/
.mypy_cache/
.ruff_cache/

*.tmp
*.cache

# =========================================
# AI GENERATED FILES (VOICE / TTS / STT)
# =========================================
audio_cache/
voice_cache/
tts_cache/
stt_cache/

generated/
outputs/
exports/

*.mp3
*.wav
*.ogg
*.flac
*.mp4

static/liao_*.mp3
static/voice_*.mp3
static/*.wav

# =========================================
# FRONTEND
# =========================================
node_modules/
dist/
build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================
# IDE / EDITORS
# =========================================
.vscode/
.idea/
*.suo
*.user

# =========================================
# OS FILES
# =========================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================
# TEST / COVERAGE
# =========================================
coverage/
htmlcov/
.coverage
coverage.xml

# =========================================
# AI MEMORY / PERSONAL DATA SAFETY
# =========================================
memory_cache/
context_cache/
session_cache/

# =========================================
# KEEP STRUCTURE ONLY
# =========================================
!.gitkeep
!data/.gitkeep
!logs/.gitkeep